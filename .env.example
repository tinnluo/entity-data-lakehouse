# This demo is file-based by default.
# No environment variables are required for the bronze -> silver -> gold run.

# ---------------------------------------------------------------------------
# Airflow credentials (required when running docker compose with the airflow service)
# ---------------------------------------------------------------------------

# Set a strong password before running docker compose up.
# The compose file will refuse to start if AIRFLOW_ADMIN_PASSWORD is unset or empty.
# Do NOT use the placeholder below directly — replace it with a real password.
AIRFLOW_ADMIN_USER=admin
# AIRFLOW_ADMIN_PASSWORD=            <-- set this to a strong password before running

# ---------------------------------------------------------------------------
# ML backend selection
# ---------------------------------------------------------------------------

# Set to "lora" to use the LoRA adapter for lifecycle-stage classification.
# Requires: pip install -e '.[lora]'  and  a trained adapter at LORA_ADAPTER_PATH.
# Default: sklearn (no env var needed)
# ML_BACKEND=lora

# Path to the saved PEFT adapter directory (only used when ML_BACKEND=lora).
# LORA_ADAPTER_PATH=models/lifecycle_lora_adapter

# ---------------------------------------------------------------------------
# Optional ClickHouse analytics backend
# ---------------------------------------------------------------------------

# Set to "true" to load gold analytics tables into ClickHouse after the pipeline.
# Requires: pip install -e '.[clickhouse]'  and  a running ClickHouse instance.
# Default: false (DuckDB only)
USE_CLICKHOUSE=false

# ClickHouse connection settings (only used when USE_CLICKHOUSE=true).
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=lakehouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# TLS settings — required for any non-localhost host.
# CLICKHOUSE_SECURE=true   # set to "true" to enable HTTPS (default port shifts to 8443)
# CLICKHOUSE_VERIFY=true   # set to "false" to skip cert verification (dev/self-signed only)
# Opt-in for the Docker Compose internal network (CLICKHOUSE_HOST=clickhouse).
# Must only be set for trusted private/compose networks; never for public hosts.
# CLICKHOUSE_ALLOW_INSECURE_PRIVATE_NETWORK=true

# ---------------------------------------------------------------------------
# Optional Langfuse observability
# ---------------------------------------------------------------------------

# When both keys are set, ML and eval flows emit traces to Langfuse.
# Leave blank (or unset) to disable tracing — local runs are unaffected.
# Requires: pip install -e '.[observability]'
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
